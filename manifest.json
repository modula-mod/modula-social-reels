{
  "id": "social-reels",
  "slug": "social-reels",
  "name": "Social Reels",
  "subtitle": "Extension plugin for Social Media",
  "description": "Adds reels surfaces, Board widgets, and media navigation to the Social parent module.",
  "version": "1.0.1",
  "type": "plugin",
  "package_kind": "plugin",
  "class": "hybrid",
  "category": "social",
  "tags": ["plugin", "social", "reels"],
  "author": "Modula",
  "publisher": "modula-mod",
  "repository": "https://github.com/modula-mod/modula-social-reels",
  "pricing": {
    "model": "free"
  },
  "assets": {
    "icon": "icon.svg"
  },
  "release": {
    "current": "1.0.1",
    "channel": "stable"
  },
  "compatibility": {
    "modula_core": ">=1.0.0",
    "api_version": "1"
  },
  "placements": [
    "board_widget"
  ],
  "extends": {
    "module_id": "social-media",
    "required": true,
    "version_range": ">=1.0.0"
  },
  "extension_slots": [
    {
      "target": "social.nav.secondary",
      "kind": "nav-item"
    },
    {
      "target": "social.profile.media",
      "kind": "media-surface"
    },
    {
      "target": "social.board.widgets",
      "kind": "widget-provider"
    }
  ],
  "surfaces": [
    {
      "type": "sidebar_page",
      "id": "reels",
      "title": "Reels",
      "parent_sidebar": "social-feed",
      "route": "/social/reels"
    },
    {
      "type": "standalone_page",
      "id": "reels-home",
      "title": "Reels",
      "route": "/social/reels"
    }
  ],
  "widgets": [
    "reels-feed"
  ],
  "permissions": [
    "profile.read",
    "widget.render",
    "post.create"
  ],
  "capabilities_required": [
    "social.feed.read",
    "social.profile.media",
    "social.board.widgets",
    "social.post.create"
  ],
  "capabilities_optional": [
    "notifications.send",
    "analytics.events.write"
  ],
  "services_required": [
    {
      "id": "social.feed.v1",
      "version_range": "^1.0.0",
      "required": true
    }
  ],
  "services_optional": [
    {
      "id": "analytics.events.v1",
      "version_range": "^1.0.0",
      "required": false
    }
  ],
  "capabilities": [
    "feed.read",
    "widget.render",
    "social.board.widgets"
  ],
  "events_emitted": [
    "social.reel.created"
  ],
  "events_listened": [
    "social.feed.updated",
    "board.widget.added"
  ],
  "actions_provided": [
    {
      "id": "social.reel.publish",
      "title": "Publish Reel",
      "capability": "social.post.create",
      "service": "social.feed.v1",
      "permissions_required": [
        "post.create"
      ]
    }
  ],
  "triggers_emitted": [
    {
      "id": "social.reel.created",
      "title": "Reel Created"
    }
  ],
  "jobs_provided": [],
  "workflows_provided": [
    {
      "id": "social.reel.publish.notify",
      "title": "Publish Reel and Notify",
      "steps": [
        "social.reel.publish",
        "notifications.send.requested"
      ]
    }
  ],
  "agent_roles": [],
  "update_channel": "stable"
}
