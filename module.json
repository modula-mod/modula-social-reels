{
  "id": "social-reels",
  "slug": "social-reels",
  "name": "Social Reels",
  "namespace": "modula.social.reels",
  "version": "1.0.0",
  "package_kind": "plugin",
  "class": "hybrid",
  "placements": [
    "board_widget"
  ],
  "extends": {
    "module_id": "social-media",
    "required": true,
    "version_range": ">=1.0.0"
  },
  "extension_slots": [
    { "target": "social.nav.secondary", "kind": "nav-item" },
    { "target": "social.profile.media", "kind": "media-surface" },
    { "target": "social.board.widgets", "kind": "widget-provider" }
  ],
  "widgets": [
    "reels-feed"
  ],
  "permissions": [
    "profile.read",
    "widget.render"
  ],
  "capabilities_required": [
    "social.feed.read",
    "social.profile.media",
    "social.board.widgets"
  ],
  "capabilities_optional": [
    "notifications.send",
    "analytics.events.write"
  ],
  "capabilities": [
    "feed.read",
    "widget.render",
    "social.board.widgets"
  ],
  "compatibility": {
    "modula_core": ">=1.0.0",
    "api_version": "1"
  },
  "update_channel": "stable"
}
